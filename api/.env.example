# ─────────────────────────────────────────────────────────────────────────
# TrackBit API — environment template
#
# Copy this file to `.env` and fill in the values:
#     cp .env.example .env            # macOS / Linux
#     Copy-Item .env.example .env     # Windows PowerShell
#
# Your team lead will share the real secret values (DB URLs, keys) privately.
# `.env` is gitignored — NEVER commit it. Only this template is committed.
# Anything marked OPTIONAL can be left empty for local development; the app
# falls back to a safe dev behaviour (printed to console / local disk / stub).
# ─────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ──────────────────────────────────────────────────
# Managed Postgres on Aiven; the database is `trackbit_school`. There is no local
# Postgres and no docker-compose db — point both URLs at Aiven.
#
# TWO ROLES, and the split is load-bearing (architectural law 2):
#   DATABASE_URL        a RESTRICTED role with NOBYPASSRLS, used by the app. If you
#                       point this at the owner, every row-level-security policy
#                       silently stops applying and orgs can read each other's data.
#   ADMIN_DATABASE_URL  the privileged owner (avnadmin). Used ONLY by `alembic`.
#
# `?sslmode=require` is mandatory — Aiven refuses plaintext connections.
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=postgresql+psycopg2://trackbit_school_app:CHANGE_ME@your-service.aivencloud.com:PORT/trackbit_school?sslmode=require

# Privileged owner role — used ONLY by `alembic` migrations:
ADMIN_DATABASE_URL=postgresql+psycopg2://avnadmin:CHANGE_ME@your-service.aivencloud.com:PORT/trackbit_school?sslmode=require

# Optional separate database used by the test suite (tests hit a real Postgres):
# TEST_DATABASE_URL=postgresql+psycopg2://trackbit_school_app:CHANGE_ME@your-service.aivencloud.com:PORT/trackbit_school_test?sslmode=require

# ── Auth (REQUIRED) ──────────────────────────────────────────────────────
# A long random string used to sign login tokens. Generate your own with:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME-generate-a-long-random-string

# ── App behaviour ────────────────────────────────────────────────────────
DEBUG=true
# Background jobs (reminders, recurrence, daily digest, absence alerts).
#
# APScheduler starts inside EACH gunicorn worker, so this must run on exactly one
# instance AND that instance must serve with a single worker — otherwise every job
# fires once per worker: two daily reports, and two absence WhatsApps to the same
# guardian. docker-entrypoint.sh enforces the worker part (forces WEB_CONCURRENCY=1
# whenever ENABLE_SCHEDULER is on); running one instance is on you.
ENABLE_SCHEDULER=true
# Gunicorn workers for instances that do NOT run the scheduler. Ignored (forced to
# 1) when ENABLE_SCHEDULER is on.
# WEB_CONCURRENCY=2
# Set false to skip `alembic upgrade head` on container start (e.g. when a separate
# release job owns migrations).
# RUN_MIGRATIONS=true
RATE_LIMIT_ENABLED=true
# Where magic-link / invite links should point (your running frontend):
FRONTEND_BASE_URL=http://localhost:3000
# Browser origins allowed to call this API (JSON array). Defaults to localhost:3000.
# CORS_ORIGINS=["http://localhost:3000"]

# ── AI — OpenRouter (OPTIONAL) ───────────────────────────────────────────
# One OpenAI-compatible endpoint, any model, one key. Get a key at
# https://openrouter.ai/keys and top it up — OpenRouter bills per token.
#
# Leave OPENROUTER_API_KEY empty and NOTHING breaks: every AI call short-circuits
# and the deterministic heuristic runs instead. The setup wizard's document import
# still finds the gaps, still asks the questions, still parses the syllabus — just
# with keyword matching rather than a model. The whole test suite runs this way.
#
# Where the key actually helps: reading a staff or roster sheet whose column
# headers don't match any keyword we know, and splitting a messily-formatted
# syllabus. AI proposes; a deterministic validator still decides what's missing,
# and the admin confirms everything on screen before a single row is written.
#
# Model ids are OpenRouter slugs (browse them at https://openrouter.ai/models).
#   AI_MODEL_DRAFT  generative work — phrasing questions, splitting syllabi
#   AI_MODEL_PARSE  structured extraction — mapping spreadsheet columns
OPENROUTER_API_KEY=
# AI_MODEL_DRAFT=anthropic/claude-opus-4.8
# AI_MODEL_PARSE=anthropic/claude-sonnet-5
# Optional: attributes your usage on the OpenRouter dashboard/leaderboards.
# OPENROUTER_SITE_URL=https://school.trackbit.in
# OPENROUTER_APP_NAME=TrackBit School
# Ingestion runs while an admin waits on a spinner — fail fast, fall back.
# AI_TIMEOUT_SECONDS=20
# AI_MAX_RETRIES=1

# ── Email — Resend (OPTIONAL) ────────────────────────────────────────────
# Leave RESEND_API_KEY empty in dev → emails are printed to the server console
# instead of being sent. Add a real key (and verified sender) to send for real.
#
# IMPORTANT: the default onboarding@resend.dev sender can ONLY deliver to your
# own Resend account email. To send to anyone, verify a domain in Resend and set
# the senders below to addresses on that domain.
#
# Senders are split by purpose (all must be on a verified domain):
#   RESEND_FROM           general/default — digests, report cards, misc
#   RESEND_FROM_LOGIN     account-access links — invites, password reset
#   RESEND_FROM_REMINDERS task reminder / overdue mails
RESEND_API_KEY=
RESEND_FROM=TrackBit <hello@notify.trackbit.in>
RESEND_FROM_LOGIN=TrackBit <login@notify.trackbit.in>
RESEND_FROM_REMINDERS=TrackBit <reminders@notify.trackbit.in>

# ── Web Push — VAPID (OPTIONAL) ──────────────────────────────────────────
# Only needed for browser push notifications. Leave empty to disable in dev.
# Ask your team lead for the shared keypair, or generate one with the `vapid`
# CLI that ships with pywebpush.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notify@trackbit.app

# ── Billing — Razorpay (OPTIONAL) ────────────────────────────────────────
# Empty → "stub mode": the upgrade flow is wired up but checkout is disabled.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_ID=
RAZORPAY_WEBHOOK_SECRET=

# ── Attachment storage — Cloudflare R2 (OPTIONAL) ────────────────────────
# Empty → files are stored on local disk under MEDIA_DIR and served from
# MEDIA_BASE_URL (perfectly fine for local dev).
MEDIA_DIR=media
MEDIA_BASE_URL=http://localhost:8000/media
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
